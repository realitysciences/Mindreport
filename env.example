# Copy this file to .env.local and fill in real values.
# Never commit .env.local to git.

# ── Beta gate ──────────────────────────────────────────────────────────────────
# Password required to access /your-map and all sub-routes.
# Set this on Vercel under Project Settings → Environment Variables.
# If unset, the gate defaults to the password "open" — insecure for production.
BETA_PASSWORD=your-password-here

# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── ElevenLabs ────────────────────────────────────────────────────────────────
# Agent ID is hardcoded in app/your-map/voice/page.tsx — no env var needed.
# If you ever rotate the agent, update it there.

# ── Resend (newsletter) ───────────────────────────────────────────────────────
RESEND_API_KEY=re_...
